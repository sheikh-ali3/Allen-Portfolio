                    <a href="#about" class="text-gray-700 hover:text-blue-900 transition">About</a>
                    <a href="/experience" class="text-gray-700 hover:text-blue-900 transition">Experience</a>
                    <a href="#services" class="text-gray-700 hover:text-blue-900 transition">Services</a>
                    <a href="#achievements" class="text-gray-700 hover:text-blue-900 transition">Achievements</a>
