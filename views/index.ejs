    <!-- Consultation Modal -->
    <div id="consultationModal" class="modal">
        <div class="bg-white rounded-lg p-8 max-w-2xl w-full mx-4 max-h-[90vh] overflow-y-auto">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-2xl font-bold text-blue-900">Book Free Consultation</h3>
                <button onclick="closeModal()" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <form id="consultationForm">
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">Full Name *</label>
                        <input type="text" name="name" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">Email *</label>
                        <input type="email" name="email" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">Phone Number *</label>
                        <input type="tel" name="phone" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">Company Name</label>
                        <input type="text" name="company" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">Consultation Type *</label>
                        <select name="consultationType" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                            <option value="">Select Type</option>
                            <option value="phone">Phone Call</option>
                            <option value="google-meet">Google Meet</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">Preferred Date *</label>
                        <input type="date" name="preferredDate" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                    </div>
                    <div>
                        <label class="block text-gray-700 font-semibold mb-2">Preferred Time *</label>
                        <select name="preferredTime" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                            <option value="">Select Time</option>
                            <option value="9:00 AM">9:00 AM</option>
                            <option value="10:00 AM">10:00 AM</option>
                            <option value="11:00 AM">11:00 AM</option>
                            <option value="2:00 PM">2:00 PM</option>
                            <option value="3:00 PM">3:00 PM</option>
                            <option value="4:00 PM">4:00 PM</option>
                        </select>
                    </div>
                    <div class="md:col-span-2">
                        <label class="block text-gray-700 font-semibold mb-2">Additional Information</label>
                        <textarea name="message" rows="4" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900" 
                                  placeholder="Tell me about your dispatch needs..."></textarea>
                    </div>
                </div>
                <div class="mt-6 flex gap-4">
                    <button type="submit" class="bg-blue-900 text-white px-6 py-3 rounded-lg hover:bg-blue-800 transition flex-1">
                        <i class="fas fa-calendar-check mr-2"></i> Book 30-Minute Consultation
                    </button>
                    <button type="button" onclick="closeModal()" class="bg-gray-300 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-400 transition">
                        Cancel
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Success Message -->
    <div id="successMessage" class="fixed top-20 right-6 bg-green-500 text-white px-6 py-4 rounded-lg shadow-lg hidden">
        <i class="fas fa-check-circle mr-2"></i>
        <span id="successText">Success!</span>
    </div>

    <script>
        // Title Animation
        const titles = ['Logistics Coordinator', 'Dispatch Manager'];
        let titleIndex = 0;
        const titleElement = document.getElementById('animated-title');
        
        function animateTitle() {
            titleElement.style.opacity = '0';
            setTimeout(() => {
                titleElement.textContent = titles[titleIndex];
                titleElement.style.opacity = '1';
                titleIndex = (titleIndex + 1) % titles.length;
            }, 500);
        }
        
        animateTitle();
        setInterval(animateTitle, 3000);
        
        // Modal Functions
        function openModal() {
            document.getElementById('consultationModal').classList.add('active');
            document.body.style.overflow = 'hidden';
        }
        
        function closeModal() {
            document.getElementById('consultationModal').classList.remove('active');
            document.body.style.overflow = 'auto';
        }
        
        // Form Submission
        document.getElementById('consultationForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);
            
            try {
                const response = await fetch('/book-consultation', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data),
                });
                
                const result = await response.json();
                
                if (result.success) {
                    closeModal();
                    showSuccessMessage(result.message);
                    e.target.reset();
                } else {
                    showSuccessMessage('Something went wrong. Please try again.', 'error');
                }
            } catch (error) {
                showSuccessMessage('Something went wrong. Please try again.', 'error');
            }
        });
        
        function showSuccessMessage(message, type = 'success') {
            const messageEl = document.getElementById('successMessage');
            const textEl = document.getElementById('successText');
            
            textEl.textContent = message;
            messageEl.className = `fixed top-20 right-6 px-6 py-4 rounded-lg shadow-lg ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            } text-white`;
            messageEl.classList.remove('hidden');
            
            setTimeout(() => {
                messageEl.classList.add('hidden');
            }, 5000);
        }
        
        // Smooth Scrolling
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
        
        // Set minimum date to today
        const dateInput = document.querySelector('input[name="preferredDate"]');
        const today = new Date().toISOString().split('T')[0];
        dateInput.min = today;
    </script>
</body>
</html>
