    <style>
        .timeline-line {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 2px;
            background: #e2e8f0;
            top: 0;
            bottom: 0;
            z-index: 1;
        }

        .timeline-progress {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 4px;
            background: linear-gradient(to bottom, #1e3a8a, #3730a3, #4c1d95);
            top: 0;
            height: 0;
            z-index: 2;
            transition: height 0.1s ease-out;
            border-radius: 2px;
        }
        
        .timeline-item {
            position: relative;
            z-index: 10;
        }
        
        .timeline-dot {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 20px;
            background: #cbd5e1;
            border: 4px solid white;
            border-radius: 50%;
            z-index: 11;
            transition: all 0.3s ease;
        }

        .timeline-dot.active {
            background: #1e3a8a;
            box-shadow: 0 0 15px rgba(30, 58, 138, 0.5);
            transform: translateX(-50%) scale(1.2);
        }
        
        @media (max-width: 768px) {
            .timeline-line { left: 20px; }
            .timeline-dot { left: 20px; }
        }

