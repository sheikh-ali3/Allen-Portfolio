            position: relative;
            z-index: 2;
        }
        
        .timeline-dot {
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            width: 20px;
            height: 20px;
            background: #1e3a8a;
            border: 4px solid white;
            border-radius: 50%;
            z-index: 3;
