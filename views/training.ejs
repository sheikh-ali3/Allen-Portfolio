                        </div>
                        <div>
                            <label class="block text-gray-700 font-semibold mb-2">Company/Individual *</label>
                            <select name="companyType" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                                <option value="">Select Type</option>
                                <option value="Company">Company</option>
                                <option value="Individual">Individual</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-700 font-semibold mb-2">Training Format *</label>
                            <select name="format" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                                <option value="">Select Format</option>
                                <option value="individual">Individual Training</option>
                                <option value="corporate">Corporate Training</option>
                                <option value="online">Online Course</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-gray-700 font-semibold mb-2">Preferred Start Date *</label>
                            <input type="date" name="startDate" required class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-gray-700 font-semibold mb-2">Training Goals</label>
                            <textarea name="goals" rows="4" class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:border-blue-900" 
                                      placeholder="Tell me about your training goals and what you hope to achieve..."></textarea>
                        </div>
                    </div>
                    <div class="mt-6 flex gap-4">
                        <button type="submit" class="bg-blue-900 text-white px-6 py-3 rounded-lg hover:bg-blue-800 transition flex-1">
                            <i class="fas fa-calendar-check mr-2"></i> Book Training Session
                        </button>
                        <button type="button" onclick="closeTrainingModal()" class="bg-gray-300 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-400 transition">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Success Message -->
    <div id="successMessage" class="fixed top-20 right-6 bg-green-500 text-white px-6 py-4 rounded-lg shadow-lg hidden">
        <i class="fas fa-check-circle mr-2"></i>
        <span id="successText">Success!</span>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-8">
        <div class="container mx-auto px-6 text-center">
            <p>&copy; 2024 Allen Whales. Professional Dispatch Manager & Trainer. All rights reserved.</p>
            <div class="mt-4 flex justify-center space-x-6">
                <a href="https://www.linkedin.com/in/allen-whales-4b5b4b1b8/" target="_blank" class="hover:text-blue-400 transition"><i class="fab fa-linkedin text-xl"></i></a>
                <a href="#" class="hover:text-blue-400 transition"><i class="fas fa-envelope text-xl"></i></a>
                <a href="#" class="hover:text-blue-400 transition"><i class="fas fa-phone text-xl"></i></a>
                <a href="/" class="hover:text-blue-400 transition"><i class="fas fa-home text-xl"></i></a>
            </div>
        </div>
    </footer>

    <script>
        function openTrainingModal(trainingType) {
            document.getElementById('trainingType').value = trainingType;
            document.getElementById('trainingModal').style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }
        
        function closeTrainingModal() {
            document.getElementById('trainingModal').style.display = 'none';
            document.body.style.overflow = 'auto';
        }
        
        // Form Submission
        document.getElementById('trainingForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData);
            
            try {
                data.formType = 'training';
                const response = await fetch('/api/submit-form', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(data),
                });
                
                const result = await response.json();
                
                if (result.success) {
                    closeTrainingModal();
                    showSuccessMessage(result.message);
                    e.target.reset();
                } else {
                    showSuccessMessage('Something went wrong. Please try again.', 'error');
                }
            } catch (error) {
                showSuccessMessage('Something went wrong. Please try again.', 'error');
            }
        });
        
        function showSuccessMessage(message, type = 'success') {
            const messageEl = document.getElementById('successMessage');
            const textEl = document.getElementById('successText');
            
            textEl.textContent = message;
            messageEl.className = `fixed top-20 right-6 px-6 py-4 rounded-lg shadow-lg ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            } text-white`;
            messageEl.classList.remove('hidden');
            
            setTimeout(() => {
                messageEl.classList.add('hidden');
            }, 5000);
        }
        
        // Set minimum date to today
        const dateInput = document.querySelector('input[name="startDate"]');
        const today = new Date().toISOString().split('T')[0];
        dateInput.min = today;
    </script>
</body>
</html>
